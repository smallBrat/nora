# Real-credential harness env file for `npm run smoke:integrations`.
#
# Copy this file to `.env.providers` (which is gitignored) and fill in only
# the providers you want to verify. The harness skips providers whose
# required vars are blank, so you can drop credentials in incrementally.
#
# Each provider page under docs/guides/integrations/<id>.mdx documents which
# fields each variable maps to.

# Developer tools
GITHUB_TOKEN=
GITLAB_TOKEN=
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
LINEAR_API_KEY=

# Communication
SLACK_BOT_TOKEN=
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
TEAMS_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SENDGRID_API_KEY=

# AI / ML
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_TOKEN=

# Cloud
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
GCP_SERVICE_ACCOUNT_JSON=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
