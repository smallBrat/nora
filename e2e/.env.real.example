# ─── Real-credential E2E config ─────────────────────────────────────────────
# Copy to e2e/.env.real and fill in. This file is read by
# e2e/specs/support/realConfig.ts. All unset values cause the dependent test
# to skip cleanly (the suite never fails because a cred is missing).

# ─── LLM provider (required) ────────────────────────────────────────────────
# Provider id as stored in /api/llm-providers (anthropic | openai | google | openrouter | ...)
REAL_LLM_PROVIDER_ID=anthropic
# Provide the key for REAL_LLM_PROVIDER_ID. REAL_LLM_API_KEY is a fallback
# for providers without a dedicated variable below.
REAL_ANTHROPIC_API_KEY=
REAL_OPENAI_API_KEY=
REAL_GOOGLE_API_KEY=
REAL_NVIDIA_API_KEY=
REAL_LLM_API_KEY=
# Optional: override the model used by the provider record
REAL_LLM_MODEL=
# NemoClaw cells force the NVIDIA provider as the default for the deploy.
REAL_NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b

# ─── Matrix cells ───────────────────────────────────────────────────────────
# Turn cells on with 1, off with 0. OpenClaw+Docker is on by default.
# Kind, AKS, GKE, and EKS all use REAL_ENABLE_OPENCLAW_K8S=1; the running
# Compose overlay decides which cluster the k8s backend targets.
REAL_ENABLE_OPENCLAW_DOCKER=1
REAL_ENABLE_OPENCLAW_K8S=0
REAL_ENABLE_OPENCLAW_NEMOCLAW=0
REAL_ENABLE_OPENCLAW_NEMOCLAW_REMOTE_DOCKER=0
REAL_ENABLE_OPENCLAW_NEMOCLAW_K8S=0
REAL_ENABLE_HERMES_DOCKER=0
REAL_ENABLE_HERMES_K8S=0
# Optional concrete execution targets. If REAL_K8S_EXECUTION_TARGET_ID is
# blank, the suite picks the first available k8s:<id> from /api/config/platform.
REAL_REMOTE_DOCKER_EXECUTION_TARGET_ID=remote:real-smoke
REAL_K8S_EXECUTION_TARGET_ID=

# Generous timeouts — cloud k8s and Hermes-first-run are slow.
REAL_PROVISION_TIMEOUT_MS=600000   # 10 minutes
REAL_CHAT_TIMEOUT_MS=120000        # 2 minutes

# ─── Integrations (§4) ──────────────────────────────────────────────────────
# GitHub: classic PAT with `repo` scope (any read-only equivalent works).
REAL_GITHUB_TOKEN=
# Slack: bot token beginning with xoxb-, with at least auth.test access.
REAL_SLACK_TOKEN=
# One URL-based integration to exercise the SSRF guard.
# Supported values for PROVIDER: grafana | jenkins | confluence
REAL_URL_INTEGRATION_PROVIDER=
REAL_URL_INTEGRATION_URL=
REAL_URL_INTEGRATION_TOKEN=
# Extra config fields as JSON (e.g. {"username":"me","email":"me@x"} for
# jenkins or confluence). Leave blank for providers that need no extras.
REAL_URL_INTEGRATION_CONFIG_JSON=

# ─── Channels (§5) ──────────────────────────────────────────────────────────
# Telegram bot token from @BotFather. Nora's OpenClaw setup smoke saves this
# into the runtime; provider delivery still requires starting the bot from the
# target Telegram account or chat.
REAL_TELEGRAM_BOT_TOKEN=
# Optional manual-delivery target; the current OpenClaw setup smoke does not
# send a legacy Nora test message.
REAL_TELEGRAM_CHAT_ID=
# Discord channel webhook (Channel Settings → Integrations → Webhooks).
# This belongs to the legacy webhook adapter, not OpenClaw's Discord Bot API.
REAL_DISCORD_WEBHOOK_URL=
# Optional OpenClaw Discord Bot API config JSON. Use this for the OpenClaw
# channel smoke once the config matches the gateway schema.
REAL_OPENCLAW_DISCORD_CONFIG_JSON=
