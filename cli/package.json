  ],
  "scripts": {
    "test": "node --test \"src/**/*.test.js\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solomon2773/nora.git",
    "directory": "cli"
  },
  "keywords": [
    "nora",
    "cli",
    "agents",
    "openclaw",
    "hermes",
    "ops",
    "self-hosted"
  ]
