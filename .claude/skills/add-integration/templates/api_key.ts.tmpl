// {{DISPLAY_NAME}} provider — connectivity check via {{API_PATH_HUMAN}}.
//
// Substitute placeholders:
//   {{ID}}                provider id, lowercase (e.g. "github")
//   {{IDPascal}}           PascalCase variable name (e.g. "github" → "github")
//   {{DISPLAY_NAME}}       human-friendly name (e.g. "GitHub")
//   {{TEST_URL}}           full URL for the connectivity check
//   {{AUTH_HEADER}}        either `Bearer ${ctx.token}` or a provider-specific scheme
//   {{IDENTITY_FIELD}}     JSON field that names the connected user/account in the test response
//   {{PRIMARY_ENV}}        primary credential env var (e.g. "GITHUB_TOKEN")
//   {{CONFIG_ENV_MAPPING}} block of `if (config.X) configEnv.X = "X_ENV"` lines (or `{}`)

import type {
  ConnectivityResult,
  DecryptedIntegration,
  EnvMapping,
  Provider,
  ProviderDeps,
} from "../types/provider";

export const {{ID}}Provider: Provider = {
  id: "{{ID}}",
  authType: "api_key",

  async test(ctx: DecryptedIntegration, deps: ProviderDeps): Promise<ConnectivityResult> {
    try {
      const res = await deps.fetch("{{TEST_URL}}", {
        headers: { Authorization: `{{AUTH_HEADER}}` },
      });
      if (!res.ok) throw new Error(`{{DISPLAY_NAME}} API returned ${res.status}`);
      const data: any = await res.json();
      return {
        success: true,
        message: `Connected as ${data.{{IDENTITY_FIELD}} || "verified"}`,
      };
    } catch (e: any) {
      return { success: false, error: e?.message ?? String(e) };
    }
  },

  mapToEnv(ctx: DecryptedIntegration): EnvMapping {
    const config = ctx.config || {};
    const configEnv: Record<string, string> = {};
    {{CONFIG_ENV_MAPPING}}
    return { primary: "{{PRIMARY_ENV}}", config: configEnv };
  },
};
