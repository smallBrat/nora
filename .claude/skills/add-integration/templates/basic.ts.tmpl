// {{DISPLAY_NAME}} provider — Basic auth (username + token) against a
// customer-controlled site URL. Mirrors providers/jira.ts. The
// site URL is validated against networkSafety to prevent SSRF.
//
// Substitute placeholders:
//   {{ID}}                provider id (lowercase)
//   {{DISPLAY_NAME}}      e.g. "Jira", "Bitbucket"
//   {{SITE_URL_KEY}}      config field that holds the base URL (e.g. "site_url")
//   {{USERNAME_KEY}}      config field that holds the username/email (e.g. "email")
//   {{TEST_PATH}}         relative path to the identity endpoint (e.g. "/rest/api/3/myself")
//   {{IDENTITY_FIELD}}    JSON field naming the connected user (e.g. "displayName")
//   {{PRIMARY_ENV}}       primary token env var (e.g. "JIRA_API_TOKEN")
//   {{CONFIG_ENV_MAPPING}} `if (config.X) configEnv.X = "X_ENV"` block

import type {
  ConnectivityResult,
  DecryptedIntegration,
  EnvMapping,
  Provider,
  ProviderDeps,
} from "../types/provider";

export const {{ID}}Provider: Provider = {
  id: "{{ID}}",
  authType: "basic",

  async test(ctx: DecryptedIntegration, deps: ProviderDeps): Promise<ConnectivityResult> {
    try {
      const config = (ctx.config || {}) as Record<string, any>;
      const domain = config.{{SITE_URL_KEY}};
      if (!domain) throw new Error("{{DISPLAY_NAME}} site URL not configured");
      const rawUrl = String(domain).includes("://") ? String(domain) : `https://${domain}`;
      const url = await deps.assertSafeUrl(rawUrl, "{{DISPLAY_NAME}} site URL");

      const username = config.{{USERNAME_KEY}};
      if (!username) throw new Error("{{DISPLAY_NAME}} {{USERNAME_KEY}} not configured");

      const credentials = Buffer.from(`${username}:${ctx.token ?? ""}`).toString("base64");
      const res = await deps.fetch(`${url}{{TEST_PATH}}`, {
        headers: {
          Authorization: `Basic ${credentials}`,
          "Content-Type": "application/json",
        },
      });
      if (!res.ok) throw new Error(`{{DISPLAY_NAME}} API returned ${res.status}`);
      const data: any = await res.json();
      return {
        success: true,
        message: `Connected as ${data.{{IDENTITY_FIELD}} || "verified"}`,
      };
    } catch (e: any) {
      return { success: false, error: e?.message ?? String(e) };
    }
  },

  mapToEnv(ctx: DecryptedIntegration): EnvMapping {
    const config = ctx.config || {};
    const configEnv: Record<string, string> = {};
    {{CONFIG_ENV_MAPPING}}
    return { primary: "{{PRIMARY_ENV}}", config: configEnv };
  },
};
