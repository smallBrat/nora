// @ts-nocheck
// Substitute:
//   {{ID}}              provider id
//   {{DISPLAY_NAME}}    e.g. "GitHub"
//   {{TEST_URL}}        URL the test() should hit
//   {{PRIMARY_ENV}}     primary access-token env var
//   {{IDENTITY_FIELD}}  identity field returned by a successful response
//   {{IDENTITY_VALUE}}  example value for the identity field

const { {{ID}}Provider } = require("../../integrations/providers/{{ID}}");

function makeDeps(fetchImpl) {
  return {
    fetch: fetchImpl,
    assertSafeUrl: async (u) => u,
    encrypt: (s) => `enc(${s})`,
    decrypt: (s) => `dec(${s})`,
    ensureEncryptionConfigured: jest.fn(),
    db: { query: jest.fn() },
  };
}

describe("{{ID}}Provider", () => {
  it("identifies as {{ID}}", () => {
    expect({{ID}}Provider.id).toBe("{{ID}}");
  });

  it("connects successfully on 2xx", async () => {
    const fetchImpl = jest.fn().mockResolvedValue({
      ok: true,
      json: async () => ({ {{IDENTITY_FIELD}}: "{{IDENTITY_VALUE}}" }),
    });
    const result = await {{ID}}Provider.test(
      { row: { provider: "{{ID}}" }, token: "tok", config: {} },
      makeDeps(fetchImpl),
    );
    expect(fetchImpl).toHaveBeenCalledWith(
      "{{TEST_URL}}",
      expect.objectContaining({
        headers: expect.objectContaining({ Authorization: expect.stringContaining("tok") }),
      }),
    );
    expect(result).toEqual({
      success: true,
      message: "Connected as {{IDENTITY_VALUE}}",
    });
  });

  it("returns success=false on non-2xx", async () => {
    const fetchImpl = jest.fn().mockResolvedValue({
      ok: false,
      status: 401,
      json: async () => ({}),
    });
    const result = await {{ID}}Provider.test(
      { row: { provider: "{{ID}}" }, token: "bad", config: {} },
      makeDeps(fetchImpl),
    );
    expect(result.success).toBe(false);
    expect(result.error).toContain("{{DISPLAY_NAME}} API returned 401");
  });

  it("maps {{PRIMARY_ENV}} as primary", () => {
    const env = {{ID}}Provider.mapToEnv({
      row: { provider: "{{ID}}" },
      token: null,
      config: {},
    });
    expect(env.primary).toBe("{{PRIMARY_ENV}}");
  });
});
